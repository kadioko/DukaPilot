{
  "name": "dukapilot-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:prod": "next start",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-test.js",
    "smoke:login": "cross-env PLAYWRIGHT_BASE_URL=https://www.dukapilot.com playwright test tests/login.smoke.spec.ts",
    "test:auth": "playwright test tests/auth.negative.spec.ts",
    "test:inventory": "playwright test tests/inventory.flows.spec.ts",
    "test:supplier": "playwright test tests/supplier.portal.spec.ts",
    "test:mocked": "playwright test tests/auth.negative.spec.ts tests/inventory.flows.spec.ts tests/supplier.portal.spec.ts",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.65.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@zxing/browser": "^0.1.5",
    "clsx": "^2.1.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "cross-env": "^7.0.3",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
