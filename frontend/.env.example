# ============================================================
# DukaPilot Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Backend API ---
# URL of the deployed backend (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- Sentry Error Tracking (optional) ---
# Client-side DSN (safe to expose publicly)
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN (keep private — do NOT prefix with NEXT_PUBLIC_)
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- App ---
NEXT_PUBLIC_APP_NAME=DukaPilot
NEXT_PUBLIC_APP_ENV=development
