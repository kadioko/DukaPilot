{
  "name": "dukaos-backend",
  "version": "1.0.0",
  "description": "DukaOS backend API - Merchant OS for Tanzania",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "start:prod": "npx prisma migrate deploy && node src/app.js",
    "dev": "nodemon src/app.js",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "smoke:prod": "node scripts/smoke-test.js",
    "test": "node --test",
    "test:api": "node --test tests/api.test.js",
    "db:backup": "node scripts/backup.js"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@sentry/node": "^10.54.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^6.6.0"
  }
}
