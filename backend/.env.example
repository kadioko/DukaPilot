# ============================================================
# DukaOS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://dukaos:dukaos_secret@localhost:5432/dukaos"
# Migration URL -- public TCP proxy, only needed for prisma migrate deploy at startup
# On Railway: set to the public Postgres URL (e.g. trolley.proxy.rlwy.net:PORT)
DATABASE_MIGRATE_URL=

# --- JWT ---
# MUST be a long random secret in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_long_random_secret_in_production"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- CORS ---
# Add your Vercel frontend URL here if not using the default
FRONTEND_URL=
VERCEL_FRONTEND_URL=

# --- Africa's Talking (OTP / SMS) ---
# Required for live OTP PIN recovery.
# Sign up at https://africastalking.com/
# Sandbox: AT_USERNAME=sandbox — OTP is logged to console, no real SMS sent.
# Production: AT_USERNAME=<your-AT-username>, AT_API_KEY=<live-key>
# Current deployment uses sandbox key (safe to share, no billing).
AT_API_KEY=atsk_096d67186d788333e15b1b75e27a4044c80b3bdef86d85487eb53a730e36e77df79cdd5b
AT_USERNAME=sandbox
AT_SENDER_ID=

# --- WhatsApp Business API (optional) ---
# If not set, orders use wa.me deep links instead.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# --- Sentry Error Tracking (optional) ---
# Get your DSN from https://sentry.io/
SENTRY_DSN=

# --- Database Backups ---
# Directory to write backups to (default: ./backups)
BACKUP_DIR=./backups
# Number of days to retain backup files
BACKUP_RETAIN_DAYS=7
# Off-site backup (Cloudflare R2 / AWS S3). Leave BACKUP_S3_BUCKET empty to
# skip off-site upload. A copy here survives even a full Railway volume wipe.
BACKUP_S3_BUCKET=
# For R2: https://<account_id>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT=
# "auto" is correct for Cloudflare R2; use the AWS region for S3
BACKUP_S3_REGION=auto
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
# Key prefix inside the bucket (default: dukaos-backups/)
BACKUP_S3_PREFIX=dukaos-backups/

# --- Mobile Money (Tanzania) — future ---
# Vodacom M-Pesa
MPESA_API_URL=
MPESA_BUSINESS_SHORT_CODE=
MPESA_PASSKEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
