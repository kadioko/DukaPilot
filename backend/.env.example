# ============================================================
# DukaOS Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://dukaos:dukaos_secret@localhost:5432/dukaos"

# --- JWT ---
# MUST be a long random secret in production.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change_this_to_a_long_random_secret_in_production"

# --- Server ---
PORT=4000
NODE_ENV=development

# --- CORS ---
# Add your Vercel frontend URL here if not using the default
FRONTEND_URL=
VERCEL_FRONTEND_URL=

# --- Africa's Talking (OTP / SMS) ---
# Required for live OTP PIN recovery.
# Sign up at https://africastalking.com/
# Use AT_USERNAME=sandbox for testing (no real SMS sent)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=

# --- WhatsApp Business API (optional) ---
# If not set, orders use wa.me deep links instead.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# --- Sentry Error Tracking (optional) ---
# Get your DSN from https://sentry.io/
SENTRY_DSN=

# --- Database Backups ---
# Directory to write backups to (default: ./backups)
BACKUP_DIR=./backups
# Number of days to retain backup files
BACKUP_RETAIN_DAYS=7

# --- Mobile Money (Tanzania) — future ---
# Vodacom M-Pesa
MPESA_API_URL=
MPESA_BUSINESS_SHORT_CODE=
MPESA_PASSKEY=
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
